---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
---

<Base>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-40 pb-28">
    <div class="max-w-2xl">
      <p class="font-mono text-xs text-blue-400/60 tracking-widest uppercase mb-8">
        Cloud Native Security Engineer · Seattle
      </p>
      <h1 class="text-5xl font-light text-white/90 leading-[1.15] tracking-tight mb-8">
        Haider<br />Mirza
      </h1>
      <p class="text-xl text-white/40 font-light leading-relaxed max-w-xl">
        I work at the intersection of cloud infrastructure, systems, and source
        code — keeping them
        <span class="text-white/60">confidential</span>,
        <span class="text-white/60">integral</span>, and
        <span class="text-white/60">available</span>.
      </p>
      <div class="flex items-center gap-6 mt-12">
        <a href="/#work" class="text-sm text-white/50 hover:text-white/80 transition-colors border-b border-white/20 pb-0.5">
          View work
        </a>
        <a href="/#contact" class="text-sm text-white/50 hover:text-white/80 transition-colors">
          Get in touch →
        </a>
      </div>
    </div>
  </section>

 <!-- Logo Banner -->
<section class="border-y border-white/5 py-6 overflow-hidden logo-banner">
  <div class="logo-track flex items-center gap-24 w-max">
    {Array(4).fill([
      { name: 'F5', img: '/logos/f5.png' },
      { name: 'Doctor Now', img: '/logos/doctornow.png' },
      { name: 'IMA Financial', img: '/logos/ima-financial.png' },
      { name: 'Boeing', img: '/logos/boeing.png' },
    ]).flat().map(({ name, img }, i) => (
      <div class="flex items-center shrink-0" aria-hidden={i >= 4 ? 'true' : undefined}>
        <img
          src={img}
          alt={name}
          class="h-7 opacity-25 grayscale transition-opacity hover:opacity-50"
        />
      </div>
    ))}
  </div>
</section>

  <!-- About -->
  <section id="about" class="max-w-5xl mx-auto px-6 py-28">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="font-mono text-xs text-white/20 tracking-widest uppercase mb-6">About</p>
        <h2 class="text-2xl font-light text-white/80 leading-relaxed mb-6">
          Systems thinker.<br />Security practitioner.
        </h2>
      </div>
      <div class="space-y-5 text-white/40 font-light leading-relaxed">
        <p>
          I don't optimise for writing fast code or chasing language features.
          I reason about systems — how they connect, where they break, and what
          happens when they're under pressure.
        </p>
        <p>
          My work spans cloud providers, Kubernetes control and data planes,
          reverse proxies, API automation, and the security boundaries between
          all of them. Across financial services, healthcare, aerospace, and
          enterprise networking.
        </p>
        <p>
          If it's complex, distributed, and needs to stay up — that's where I do
          my best work.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills -->
<section class="max-w-5xl mx-auto px-6 pb-28">
  <div class="border-t border-white/5 pt-16">
    <p class="font-mono text-xs text-white/20 tracking-widest uppercase mb-10">Capabilities</p>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-white/[0.05]">
      {[
        { area: 'Infrastructure & Cloud', items: ['AWS', 'GCP', 'Azure', 'Linux', 'Docker', 'Git'] },
        { area: 'Kubernetes & Service Mesh', items: ['Kubernetes', 'Envoy', 'Control Plane', 'Data Plane', 'Admission Controllers', 'Istio', 'Cilium'] },
        { area: 'Networking', items: ['DNS', 'TCP/UDP', 'IPv4/IPv6', 'BGP', 'Reverse Proxies', 'Load Balancing'] },
        { area: 'Security', items: ['Zero Trust', 'mTLS', 'WAF', 'SSO', 'OAuth', 'IAM', 'RBAC'] },
        { area: 'Automation & Dev', items: ['API Design', 'CI/CD', 'GitOps', 'Terraform'] },
      ].map((group) => (
        <div class="bg-[#1a1a1a] p-6">
          <p class="text-xs text-white/30 font-mono mb-4 tracking-wide">{group.area}</p>
          <ul class="space-y-2">
            {group.items.map((item) => (
              <li class="text-sm text-white/40 font-light">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

  <!-- Case Studies -->
  <section id="work" class="max-w-5xl mx-auto px-6 pb-28">
    <div class="border-t border-white/5 pt-16">
      <p class="font-mono text-xs text-white/20 tracking-widest uppercase mb-10">Case Studies</p>
      <div class="space-y-px bg-white/5">
        {caseStudies.length > 0 ? caseStudies.map((study) => (
          <a
            href={`/case-studies/${study.slug}`}
            class="group flex items-start justify-between gap-8 bg-[#1a1a1a] p-8 hover:bg-white/[0.02] transition-colors"
          >
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="font-mono text-xs text-blue-400/60 tracking-widest uppercase">{study.data.client}</span>
                <span class="text-white/10">·</span>
                <span class="font-mono text-xs text-white/20">{study.data.date}</span>
              </div>
              <h3 class="text-lg font-light text-white/70 group-hover:text-white/90 transition-colors mb-3">
                {study.data.title}
              </h3>
              <p class="text-sm text-white/30 font-light leading-relaxed max-w-xl">
                {study.data.summary}
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                {study.data.tags.map((tag) => (
                  <span class="font-mono text-xs text-white/20 border border-white/10 rounded px-2 py-0.5">{tag}</span>
                ))}
              </div>
            </div>
            <span class="text-white/20 group-hover:text-white/50 transition-colors mt-1 text-lg">→</span>
          </a>
        )) : (
          <div class="bg-[#1a1a1a] p-8 text-white/20 text-sm font-light font-mono">
            Case studies coming soon.
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="max-w-5xl mx-auto px-6 pb-28">
    <div class="border-t border-white/5 pt-16">
      <div class="max-w-lg">
        <p class="font-mono text-xs text-white/20 tracking-widest uppercase mb-6">Contact</p>
        <h2 class="text-2xl font-light text-white/80 mb-4">Let's talk.</h2>
        <p class="text-white/40 font-light leading-relaxed mb-10">
          If you're dealing with a hard systems or security problem and need
          someone who can reason about it end-to-end, reach out.
        </p>
        <div class="space-y-4">
          <a href="mailto:haider@haidermirza.dev" class="flex items-center gap-3 text-white/40 hover:text-white/70 transition-colors group">
            <span class="font-mono text-xs text-white/20 w-20">Email</span>
            <span class="text-sm group-hover:underline underline-offset-4">haider@haidermirza.dev</span>
          </a>
          <a href="https://www.linkedin.com/in/itsmemirza" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-white/40 hover:text-white/70 transition-colors group">
            <span class="font-mono text-xs text-white/20 w-20">LinkedIn</span>
            <span class="text-sm group-hover:underline underline-offset-4">linkedin.com/in/haidermirza</span>
          </a>
          <a href="https://github.com/ItismeMirza" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-white/40 hover:text-white/70 transition-colors group">
            <span class="font-mono text-xs text-white/20 w-20">GitHub</span>
            <span class="text-sm group-hover:underline underline-offset-4">github.com/haidermirza</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
